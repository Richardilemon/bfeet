{
  "$schema": "https://schema.railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd evangelism-heatmap && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd evangelism-heatmap && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "restartPolicyType": "ON_FAILURE"
  }
}
